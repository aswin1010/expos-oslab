//INIT
loadi(65,7);
loadi(66,8);

//INT 10 MODULE
loadi(22,35);
loadi(23,36);

//EXCEPTION HANDLER
loadi(2,15);
loadi(3,16);

PTBR = PAGE_TABLE_BASE;
